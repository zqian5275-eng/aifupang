# 巨潮 orgId 映射缓存
_CNINFO_ORGID_MAP = {}

def _cninfo_orgid(code):
    """查股票真实 orgId"""
    global _CNINFO_ORGID_MAP
    if not _CNINFO_ORGID_MAP:
        try:
            r = requests.get("http://www.cninfo.com.cn/new/data/szse_stock.json",
                             headers={"User-Agent": UA}, timeout=15)
            _CNINFO_ORGID_MAP = {s["code"]: s["orgId"] for s in r.json().get("stockList", [])}
        except Exception as e:
            print(f"[WARN] 巨潮orgId映射表拉取失败: {e}")
    org = _CNINFO_ORGID_MAP.get(code)
    if org:
        return org
    if code.startswith("6"):
        return f"gssh0{code}"
    elif code.startswith("8") or code.startswith("4"):
        return f"gsbj0{code}"
    return f"gssz0{code}"

def _cninfo_ts_to_date(ts):
    if isinstance(ts, (int, float)):
        return datetime.fromtimestamp(ts / 1000).strftime("%Y-%m-%d")
    return str(ts)[:10] if ts else ""


def get_announcements(code):
    """巨潮公告"""
    code_num = code[2:] if code.startswith('sh') or code.startswith('sz') else code
    try:
        url = "https://www.cninfo.com.cn/new/hisAnnouncement/query"
        org_id = _cninfo_orgid(code_num)
        payload = {
            "stock": f"{code_num},{org_id}",
            "tabName": "fulltext", "pageSize": "20", "pageNum": "1",
            "column": "", "category": "", "plate": "", "seDate": "",
            "searchkey": "", "secid": "", "sortName": "", "sortType": "",
            "isHLtitle": "true",
        }
        headers = {
            "User-Agent": UA,
            "Content-Type": "application/x-www-form-urlencoded",
            "Referer": "https://www.cninfo.com.cn/new/disclosure",
            "Origin": "https://www.cninfo.com.cn",
        }
        r = requests.post(url, data=payload, headers=headers, timeout=15)
        d = r.json()
        rows = []
        for item in d.get("announcements", []) or []:
            rows.append({
                'title': item.get("announcementTitle", ""),
                'code': item.get("announcementId", ""),
                'date': _cninfo_ts_to_date(item.get("announcementTime")),
                'type': item.get("announcementTypeName", ""),
                'url': f"https://www.cninfo.com.cn/new/disclosure/detail?annoId={item.get('announcementId', '')}"
            })
        return rows
    except Exception as e:
        print(f"[WARN] 公告获取失败: {e}")
        return []


# ============ 7. 基础数据 ============
def get_financial_table(code, table_type='income'):
    """新浪财报三表"""
    code_num = code[2:] if code.startswith('sh') or code.startswith('sz') else code
    prefix = "sh" if code.startswith('sh') else "sz"
    report_type = {"income": "lrb", "balance": "fzb", "cashflow": "llb"}.get(table_type, "lrb")
    try:
        url = "https://quotes.sina.cn/cn/api/openapi.php/CompanyFinanceService.getFinanceReport2022"
        params = {
            "paperCode": f"{prefix}{code_num}",
            "source": report_type, "type": "0", "page": "1", "num": "8",
        }
        headers = {"User-Agent": UA}
        r = requests.get(url, params=params, headers=headers, timeout=15)
        report_list = r.json().get("result", {}).get("data", {}).get("report_list", {}) or {}
        rows = []
        for period in sorted(report_list.keys(), reverse=True)[:8]:
            obj = report_list[period]
            rec = {"报告期": f"{period[:4]}-{period[4:6]}-{period[6:8]}"}
            for it in obj.get("data", []) or []:
                title = it.get("item_title", "")
                if not title or it.get("item_value") is None:
                    continue
                rec[title] = it.get("item_value")
                tongbi = it.get("item_tongbi")
                if tongbi not in (None, ""):
                    rec[title + "_同比"] = tongbi
            rows.append(rec)
        headers_list = ["报告期"] + list(set(k for r in rows for k in r.keys() if k != "报告期"))
        return {'table': table_type, 'title': _get_table_title(table_type),
                'headers': headers_list, 'data': rows}
    except Exception as e:
        print(f"[WARN] 财报获取失败: {e}")
    return {'table': table_type, 'title': _get_table_title(table_type), 'headers': ['报告期'], 'data': []}

def _get_table_title(t):
    return {'income': '利润表', 'balance': '资产负债表', 'cashflow': '现金流量表'}.get(t, '财报')


# ============ 8. 搜索 ============
def search_stock(keyword):
    """搜索股票"""
    results = []
    try:
        r = requests.get(
            f'https://web.ifzq.gtimg.cn/appstock/app/fqkline/get?param={keyword},day,,,1,qfq',
            timeout=10
        )
        data = r.json()
        for key, val in data.get('data', {}).items():
            qt = val.get('qt', {})
            sd = qt.get(key, qt.get('sh' + key, qt.get('sz' + key, [])))
            if sd:
                results.append({'code': sd[2], 'name': sd[1], 'full_code': key})
    except Exception as e:
        print(f"[WARN] 搜索失败: {e}")
    return results


# ============ 9. 股东户数 ============
def get_holder_num(code):
    """股东户数变化 - 东财为主，Tushare备选"""
    code_num = code[2:] if code.startswith('sh') or code.startswith('sz') else code
    try:
        if _check_em_available():
            data = eastmoney_datacenter(
                "RPT_HOLDERNUMLATEST",
                filter_str=f'(SECURITY_CODE="{code_num}")',
                page_size=10, sort_columns="END_DATE", sort_types="-1"
            )
            result = []
            for row in data:
                result.append({
                    'date': str(row.get('END_DATE', ''))[:10],
                    'holder_num': row.get('HOLDER_NUM', 0),
                    'change_num': row.get('HOLDER_NUM_CHANGE', 0),
                    'change_ratio': row.get('HOLDER_NUM_RATIO', 0),
                    'avg_shares': row.get('AVG_FREE_SHARES', 0),
                })
            if result:
                return result
    except Exception as e:
        print(f"[WARN] 东财股东户数获取失败: {e}")
    
    # Tushare备选
    result = []
    try:
        pro = get_ts_pro()
        if pro:
            ts_code = _to_ts_code(code)
            start_date = _days_ago_str(365 * 3)
            end_date = _today_str()
            df = pro.stk_holdernumber(ts_code=ts_code, start_date=start_date, end_date=end_date)
            if df is not None and not df.empty:
                df = df.sort_values('end_date', ascending=False)
                prev_holders = None
                for _, row in df.head(10).iterrows():
                    curr = row.get('holder_num', 0)
                    change = curr - prev_holders if prev_holders is not None else 0
                    ratio = (change / prev_holders * 100) if prev_holders else 0
                    result.append({
                        'date': str(row.get('end_date', ''))[:10],
                        'holder_num': int(curr),
                        'change_num': int(change),
                        'change_ratio': round(ratio, 2),
                        'avg_shares': 0
                    })
                    prev_holders = curr
    except Exception as e:
        print(f"[WARN] Tushare股东户数也失败: {e}")
    
    return result


# ============ 10. 分红送转 ============
def get_dividend(code):
    """分红送转历史 - 东财为主，Tushare备选"""
    code_num = code[2:] if code.startswith('sh') or code.startswith('sz') else code
    try:
        if _check_em_available():
            data = eastmoney_datacenter(
                "RPT_SHAREBONUS_DET",
                filter_str=f'(SECURITY_CODE="{code_num}")',
                page_size=20, sort_columns="EX_DIVIDEND_DATE", sort_types="-1"
            )
            if data:
                result = []
                for row in data:
                    result.append({
                        'date': str(row.get('EX_DIVIDEND_DATE', ''))[:10],
                        'bonus_rmb': row.get('PRETAX_BONUS_RMB', 0),
                        'transfer_ratio': row.get('TRANSFER_RATIO', 0),
                        'bonus_ratio': row.get('BONUS_RATIO', 0),
                        'plan': row.get('ASSIGN_PROGRESS', ''),
                    })
                return result
    except Exception as e:
        print(f"[WARN] 东财分红获取失败: {e}")
    
    # Tushare备选
    result = []
    try:
        pro = get_ts_pro()
        if pro:
            ts_code = _to_ts_code(code)
            df = pro.dividend(ts_code=ts_code, fields='ts_code,end_date,stk_div,stk_bo_rate,stk_co_rate,cash_div,record_date,ex_date,div_proc')
            if df is not None and not df.empty:
                # 只保留「实施」的分红方案（预案/股东大会通过的 cash_div=0）
                df = df[df['div_proc'] == '实施'] if 'div_proc' in df.columns else df
                # 按除权日去重，保留最新
                df = df.sort_values('ex_date', ascending=False).drop_duplicates(subset=['end_date'], keep='first')
                df = df.sort_values('end_date', ascending=False)
                for _, row in df.head(20).iterrows():
                    def safe_float(v):
                        try:
                            f = float(v)
                            return 0 if math.isnan(f) else f
                        except:
                            return 0
                    def safe_date(v):
                        if v and str(v) != 'nan' and str(v) != 'None':
                            return str(v)[:10]
                        return ''
                    ex = safe_date(row.get('ex_date'))
                    end = safe_date(row.get('end_date'))
                    result.append({
                        'date': ex or end,
                        'bonus_rmb': safe_float(row.get('cash_div', 0)),
                        'transfer_ratio': safe_float(row.get('stk_co_rate', 0)),
                        'bonus_ratio': safe_float(row.get('stk_bo_rate', 0)),
                        'plan': '实施' if ex else '预案',
                    })
    except Exception as e:
        print(f"[WARN] Tushare分红也失败: {e}")
    
    return result


# ============ 11. 宏观数据 ============
# 宏观数据缓存（减少Tushare调用）
_MACRO_CACHE = {}
_MACRO_CACHE_TIME = {}

def _get_macro_cache(key):
    if key in _MACRO_CACHE and time.time() - _MACRO_CACHE_TIME.get(key, 0) < 3600:
        return _MACRO_CACHE[key]
    return None

def _set_macro_cache(key, data):
    _MACRO_CACHE[key] = data
    _MACRO_CACHE_TIME[key] = time.time()

def clear_macro_cache():
    """清除宏观数据缓存（用于调试）"""
    _MACRO_CACHE.clear()
    _MACRO_CACHE_TIME.clear()


