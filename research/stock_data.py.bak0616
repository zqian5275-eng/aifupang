    return result


# ============ 6. 新闻 & 公告 ============
def get_individual_news(code):
    """个股新闻 - 东财为主，Tushare重大公告备选"""
    code_num = code[2:] if code.startswith('sh') or code.startswith('sz') else code
    rows = []
    
    # 先尝试东财（search-api-web 子域名未被封）
    try:
        cb = "jQuery_news"
        url = "https://search-api-web.eastmoney.com/search/jsonp"
        inner_params = json.dumps({
            "uid": "", "keyword": code_num,
            "type": ["cmsArticleWebOld"],
            "client": "web", "clientType": "web", "clientVersion": "curr",
            "param": {"cmsArticleWebOld": {"searchScope": "default", "sort": "default",
                      "pageIndex": 1, "pageSize": 20, "preTag": "", "postTag": ""}},
        }, separators=(',', ':'))
        params = {"cb": cb, "param": inner_params}
        headers = {"User-Agent": UA, "Referer": "https://so.eastmoney.com/"}
        r = requests.get(url, params=params, headers=headers, timeout=15)
        text = r.text
        json_str = text[text.index("(") + 1 : text.rindex(")")]
        d = json.loads(json_str)
        articles = d.get("result", {}).get("cmsArticleWebOld", []) or []
        for a in articles:
            rows.append({
                'title': re.sub(r'<[^>]+>', '', a.get("title", "")),
                'time': a.get("date", ""),
                'media': a.get("mediaName", ""),
                'summary': re.sub(r'<[^>]+>', '', a.get("content", ""))[:200],
                'url': a.get("url", "")
            })
        if rows:
            return rows
    except Exception as e:
        print(f"[WARN] 东财新闻失败，尝试Tushare: {e}")
    
    # 东财失败，用Tushare重大公告备选
    try:
        pro = get_ts_pro()
        if pro:
            ts_code = _to_ts_code(code)
            start_date = _days_ago_str(30)
            end_date = _today_str()
            # 尝试获取重大合同、业绩快报等
            df = pro.major_news(ts_code=ts_code, start_date=start_date, end_date=end_date)
            if df is not None and not df.empty:
                for _, row in df.iterrows():
                    rows.append({
                        'title': row.get('title', ''),
                        'time': row.get('date', ''),
                        'media': 'Tushare',
                        'summary': row.get('content', '')[:200],
                        'url': ''
                    })
    except Exception as e:
        print(f"[WARN] Tushare新闻也失败: {e}")
    
    return rows


