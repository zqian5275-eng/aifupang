def _av_get_cpi_yoy(max_rows=24):
    """Alpha Vantage: 获取美国CPI年率（从指数换算出YoY%）"""
    try:
        r = requests.get(
            "https://www.alphavantage.co/query",
            params={"function": "CPI", "interval": "monthly", "apikey": "demo"},
            timeout=15
        )
        d = r.json()
        data = d.get("data", [])
        if not data:
            return []
        
        # Build index lookup
        index_data = {}
        for item in data:
            val = item.get("value", ".")
            if val == ".":
                continue
            index_data[item["date"]] = float(val)
        
        # Calculate YoY
        result = []
        for date in sorted(index_data.keys(), reverse=True):
            parts = date.split("-")
            year_ago = str(int(parts[0]) - 1) + "-" + parts[1] + "-01"
            if year_ago in index_data:
                yoy = round((index_data[date] / index_data[year_ago] - 1) * 100, 1)
                prev = result[-1]["value"] if result else None
                result.append({
                    "date": date,
                    "value": yoy,
                    "forecast": None,
                    "previous": prev
                })
            if len(result) >= max_rows:
                break
        
        return result
    except Exception as e:
        print(f"[WARN] Alpha Vantage CPI获取失败: {e}")
        return []


def _jin10_get(attr_id, symbol_name, max_rows=24):
    """金十数据中心API获取美国宏观数据（参考akshare实现）"""
    headers = {
        "user-agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) "
                      "Chrome/120.0.0.0 Safari/537.36",
        "x-app-id": "rU6QIu7JHe2gOUeR",
        "x-csrf-token": "x-csrf-token",
        "x-version": "1.0.0",
    }
    url = "https://datacenter-api.jin10.com/reports/list_v2"
    t = time.time()
    params = {
        "max_date": "",
        "category": "ec",
        "attr_id": str(attr_id),
        "_": str(int(round(t * 1000))),
    }
    try:
        r = requests.get(url, params=params, headers=headers, timeout=15)
        d = r.json()
        values = d.get("data", {}).get("values", [])
        if not values:
            print(f"[WARN] 金十数据 {symbol_name} 返回空")
            return []
        rows = []
        for item in values[:max_rows]:
            val = item[1] if len(item) > 1 else None
            # 跳过预发布的null值行（未来数据占位）
            if val is None or val == '':
                continue
            rows.append({
                'date': item[0] if len(item) > 0 else '',
                'value': float(val),
                'forecast': float(item[2]) if len(item) > 2 and item[2] not in (None, '') else None,
                'previous': float(item[3]) if len(item) > 3 and item[3] not in (None, '') else None,
            })
        return rows
    except Exception as e:
        print(f"[WARN] 金十数据 {symbol_name} 请求失败: {e}")
        return []


def _eastmoney_usa_indicator(indicator_id, indicator_name, max_rows=24):
    """东方财富-美国宏观经济指标"""
    if not _check_em_available():
        print(f"[WARN] 东财不可达，跳过 {indicator_name}")
        return []
    url = "https://datacenter-web.eastmoney.com/api/data/v1/get"
    params = {
        "reportName": "RPT_ECONOMICVALUE_USA",
        "columns": "ALL",
        "filter": f'(INDICATOR_ID="{indicator_id}")',
        "pageNumber": "1",
        "pageSize": str(max_rows),
        "sortColumns": "REPORT_DATE",
        "sortTypes": "-1",
        "source": "WEB",
        "client": "WEB",
    }
    try:
        r = requests.get(url, params=params, timeout=15)
        d = r.json()
        data_list = d.get("result", {}).get("data", [])
        if not data_list:
            print(f"[WARN] 东财 {indicator_name} 返回空")
            return []
        rows = []
        for item in data_list[:max_rows]:
            val = item.get('VALUE')
            # 跳过预发布的null值行（未来数据）
            if val is None:
                continue
            rows.append({
                'date': str(item.get('REPORT_DATE', ''))[:10],
                'value': float(val),
                'previous': float(item.get('PRE_VALUE', 0) or 0),
            })
        return rows
    except Exception as e:
        print(f"[WARN] 东财 {indicator_name} 请求失败: {e}")
        return []


def get_macro_usa():
    """美国宏观数据：通过金十数据+东方财富API获取关键指标（真实数据）"""
    result = {}

    # 汇率作为参考
    try:
        url = "https://api.exchangerate-api.com/v4/latest/USD"
        r = requests.get(url, timeout=10)
        d = r.json()
        result['usd_cny'] = d.get('rates', {}).get('CNY', 0)
        result['usd_cny_date'] = d.get('date', '')
    except Exception as e:
        print(f"[WARN] 汇率获取失败: {e}")

    # 1. 美国CPI年率 - Alpha Vantage (最新数据，含YoY换算)
    cached = _get_macro_cache('us_cpi')
    if cached is not None:
        result['cpi'] = cached
    else:
        rows = _av_get_cpi_yoy(24)
        if rows:
            result['cpi'] = rows
            _set_macro_cache('us_cpi', rows)

    # 2. 美国非农就业人数 - 金十数据 (attr_id=33)
    cached = _get_macro_cache('us_payroll')
    if cached is not None:
        result['payroll'] = cached
    else:
        rows = _jin10_get("33", "美国非农就业人数")
        if rows:
            result['payroll'] = rows
            _set_macro_cache('us_payroll', rows)

    # 3. 美国失业率 - 金十数据 (attr_id=47)
    cached = _get_macro_cache('us_unemployment')
    if cached is not None:
        result['unemployment'] = cached
    else:
        rows = _jin10_get("47", "美国失业率")
        if rows:
            result['unemployment'] = rows
            _set_macro_cache('us_unemployment', rows)

    # 4. 美联储利率（联邦基金利率）- Alpha Vantage
    cached = _get_macro_cache('us_fedrate')
    if cached is not None:
        result['fed_rate'] = cached
    else:
        try:
            r = requests.get(
                "https://www.alphavantage.co/query",
                params={"function": "FEDERAL_FUNDS_RATE", "interval": "monthly", "apikey": "demo"},
                timeout=15
            )
            d = r.json()
            av_data = d.get("data", [])
            rows = []
            for item in av_data[:24]:
                val = item.get("value", ".")
                if val == ".":
                    continue
                rows.append({
                    "date": item["date"],
                    "value": float(val),
                    "forecast": None,
                    "previous": rows[-1]["value"] if rows else None
                })
            if rows:
                result['fed_rate'] = rows
                _set_macro_cache('us_fedrate', rows)
        except Exception as e:
            print(f"[WARN] Alpha Vantage Fed Rate获取失败: {e}")

    # 5. 美国GDP - 金十数据 (attr_id=53)
    cached = _get_macro_cache('us_gdp')
    if cached is not None:
        result['gdp'] = cached
    else:
        rows = _jin10_get("53", "美国GDP")
        if rows:
            result['gdp'] = rows
            _set_macro_cache('us_gdp', rows)

    return result


def get_macro_calendar():
    """经济数据发布日历（最近30天和 upcoming）"""
    calendar = []
    today = datetime.now()
    
    # 中国常规数据发布时间（基于历史规律）
    regular_releases = [
        {'name': 'CPI', 'freq': '月度', 'day': 9, 'country': '中国'},
        {'name': 'PPI', 'freq': '月度', 'day': 9, 'country': '中国'},
        {'name': 'M2', 'freq': '月度', 'day': 10, 'country': '中国'},
        {'name': '贸易帐', 'freq': '月度', 'day': 8, 'country': '中国'},
        {'name': 'GDP', 'freq': '季度', 'months': [1,4,7,10], 'day': 18, 'country': '中国'},
        {'name': 'PMI', 'freq': '月度', 'day': 31, 'country': '中国'},
        {'name': '美国CPI', 'freq': '月度', 'day': 13, 'country': '美国'},
        {'name': '美国非农', 'freq': '月度', 'day': 5, 'country': '美国'},
        {'name': '美联储利率决议', 'freq': '季度', 'months': [1,3,5,7,9,11], 'day': 20, 'country': '美国'},
        {'name': '美国GDP', 'freq': '季度', 'months': [1,4,7,10], 'day': 25, 'country': '美国'},
    ]
    
    # 生成最近3个月和未来1个月的日历
    for month_offset in range(-3, 2):
        month_date = today.replace(day=1) + timedelta(days=month_offset*30)
        month_date = month_date.replace(day=1)
        for rel in regular_releases:
            if rel['freq'] == '月度':
                release_date = month_date.replace(day=min(rel['day'], 28))
                calendar.append({
                    'date': release_date.strftime('%Y-%m-%d'),
                    'name': rel['name'],
                    'country': rel['country'],
                    'freq': rel['freq'],
                    'status': '已发布' if release_date < today else '待发布'
                })
            elif rel['freq'] == '季度':
                if month_date.month in rel['months']:
                    release_date = month_date.replace(day=min(rel['day'], 28))
                    calendar.append({
                        'date': release_date.strftime('%Y-%m-%d'),
                        'name': rel['name'],
                        'country': rel['country'],
                        'freq': rel['freq'],
                        'status': '已发布' if release_date < today else '待发布'
                    })
    
    # 去重并排序
    seen = set()
    unique = []
    for item in sorted(calendar, key=lambda x: x['date']):
        key = (item['date'], item['name'])
        if key not in seen:
            seen.add(key)
            unique.append(item)
    
    return unique[-60:]  # 返回最近60条

# ============ 研报列表 ============
REPORT_API_URL = "https://reportapi.eastmoney.com/report/list"
PDF_URL_TPL = "https://pdf.dfcfw.com/pdf/H3_{info_code}_1.pdf"

def get_reports(code, max_pages=3):
    """东财研报列表 - reportapi.eastmoney.com（未被封）"""
    code_num = code[2:] if code.startswith('sh') or code.startswith('sz') else code
    all_records = []
    try:
        for page in range(1, max_pages + 1):
            params = {
                "industryCode": "*", "pageSize": "50", "industry": "*",
                "rating": "*", "ratingChange": "*",
                "beginTime": "2024-01-01", "endTime": "2030-01-01",
                "pageNo": str(page), "fields": "", "qType": "0",
                "orgCode": "", "code": code_num, "rcode": "",
                "p": str(page), "pageNum": str(page), "pageNumber": str(page),
            }
            r = requests.get(REPORT_API_URL, params=params,
                           headers={"User-Agent": UA, "Referer": "https://data.eastmoney.com/"},
                           timeout=15)
            d = r.json()
            rows = d.get("data") or []
            if not rows:
                break
            all_records.extend(rows)
            if page >= (d.get("TotalPage", 1) or 1):
                break
        
        result = []
        for item in all_records[:50]:
            result.append({
                'title': item.get('title', ''),
                'date': str(item.get('publishDate', ''))[:10],
                'org': item.get('orgSName', '') or item.get('orgName', ''),
                'rating': item.get('emRatingName', ''),
                'eps_this_year': item.get('predictThisYearEps', ''),
                'eps_next_year': item.get('predictNextYearEps', ''),
                'eps_two_year': item.get('predictNextTwoYearEps', ''),
                'info_code': item.get('infoCode', ''),
                'stock_name': item.get('stockName', ''),
            })
        return result
    except Exception as e:
        print(f"[WARN] 研报获取失败: {e}")
        return []

